    "prisma:generate": "prisma generate"
  },
  "imports": {
    "@/": "./",
    "@felix/bcrypt": "jsr:@felix/bcrypt@^1.0.8",
    "@momiji/cors": "jsr:@momiji/cors@^1.0.1",
    "@oak/oak": "jsr:@oak/oak@^17.2.0",
    "@panva/jose": "jsr:@panva/jose@^6.1.3",
    "@prisma/adapter-pg": "npm:@prisma/adapter-pg@^7.4.0",
    "@prisma/client": "npm:@prisma/client@^7.4.0",
    "@std/assert": "jsr:@std/assert@1",
    "@types/pg": "npm:@types/pg@^8.16.0",
    "@zod/zod": "jsr:@zod/zod@^4.3.6",
    "dotenv": "npm:dotenv@^17.3.1",
    "pg": "npm:pg@^8.18.0",
    "prisma": "npm:prisma@^7.4.0"
